# Environment variables for running tests locally (outside Docker).
# Copy values to match your local Postgres setup.
# When running via `make test-api`, these are set programmatically in conftest.py.

# Override the main DB so tests never touch production data.
TEST_DATABASE_URL=postgresql+asyncpg://appuser:apppassword@localhost:5432/meetingmemo_test

# The test conftest.py reads TEST_DATABASE_URL and sets DATABASE_URL accordingly.
# You must create the test database first:
#   docker compose -f infra/docker-compose.yml exec db \
#     psql -U appuser -c "CREATE DATABASE meetingmemo_test;"

SECRET_KEY=test-secret-key-do-not-use-in-production
OPENAI_API_KEY=test-key-not-real
